---
interface Props {
  brandName?: string;
  tagline?: string;
  address?: string;
  phoneLabel?: string;
  phoneHref?: string;
  email?: string;
}

const {
  brandName = "[Business Name]",
  tagline = "[Your business tagline - what you do and who you serve]",
  address = "[Your City], [Your Region]",
  phoneLabel = "[Your Phone]",
  phoneHref = "tel:[Your Phone]",
  email = "[Your Email]",
} = Astro.props as Props;

const siteLinks = [
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "Sitemap", href: "/sitemap-index.xml" },
];

const servicesLinks = [
  { label: "[Service 1]", href: "/services" },
  { label: "[Service 2]", href: "/services" },
  { label: "Our Facility", href: "/our-home" },
];
---

<footer class="bg-[#F6F0D8] text-[#365C1C] border-t border-[#B69F38]/20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      
      <!-- Brand Column -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-[#365C1C] text-white">
            <span class="text-xl font-serif font-bold">U</span>
          </div>
          <span class="text-xl font-serif font-bold tracking-tight text-[#365C1C]">
            {brandName}
          </span>
        </div>
        <p class="text-sm text-[#365C1C]/80 leading-relaxed">
          {tagline}
        </p>
      </div>

      <!-- Site Links Column -->
      <div>
        <h3 class="font-serif font-bold text-lg mb-4 text-[#B69F38]">Site Links</h3>
        <ul class="space-y-3">
          {siteLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium hover:text-[#B69F38] transition-colors inline-flex items-center gap-1"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-serif font-bold text-lg mb-4 text-[#B69F38]">Services</h3>
        <ul class="space-y-3">
          {servicesLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium hover:text-[#B69F38] transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-serif font-bold text-lg mb-4 text-[#B69F38]">Contact</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <svg class="size-5 text-[#B69F38] mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href={`mailto:${email}`} class="hover:text-[#B69F38] transition-colors">{email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-5 text-[#B69F38] mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href={phoneHref} class="hover:text-[#B69F38] transition-colors">{phoneLabel}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="size-5 text-[#B69F38] mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>{address}</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-[#365C1C]/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-[#365C1C]/60">
      <p>© {new Date().getFullYear()} {brandName}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-[#365C1C] transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-[#365C1C] transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-[#365C1C] transition-colors">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

