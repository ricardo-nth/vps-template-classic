---
import { careProfileConfig } from '@/config/site';

interface Props {
  eyebrow?: string;
  heading?: string;
  subheading?: string;
  profileContent?: {
    'supported-living'?: { heading?: string; subheading?: string };
    'dom-care'?: { heading?: string; subheading?: string };
  };
}

const {
  eyebrow = "Our services",
  heading = "[Page Heading]",
  subheading = "[Page intro - briefly describe this service]",
  profileContent = {},
} = Astro.props as Props;

const instanceId = `page-hero-${Math.random().toString(36).slice(2, 9)}`;
const { defaultProfile } = careProfileConfig;
---

<section
  id={instanceId}
  class="relative min-h-[70vh] flex items-center justify-center overflow-hidden"
  data-care-profile-content
>
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-secondary via-background to-secondary/50"></div>

  <!-- Decorative elements -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary/5 to-transparent"></div>
  <div class="absolute bottom-0 left-0 w-1/3 h-1/2 bg-gradient-to-t from-accent/10 to-transparent"></div>

  <!-- Decorative shapes -->
  <div class="absolute top-20 right-20 w-64 h-64 rounded-full bg-primary/5 blur-3xl"></div>
  <div class="absolute bottom-20 left-20 w-48 h-48 rounded-full bg-accent/10 blur-2xl"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-24 lg:py-32">
    {eyebrow && (
      <div class="inline-flex items-center gap-2 mb-8">
        <span class="h-px w-8 bg-primary"></span>
        <span class="text-sm font-semibold uppercase tracking-widest text-primary">
          {eyebrow}
        </span>
        <span class="h-px w-8 bg-primary"></span>
      </div>
    )}

    <h1
      class="font-serif text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-primary mb-8 leading-tight tracking-tight [&>span]:text-accent [&>span]:font-medium"
      data-care-field="heading"
    >
      <Fragment set:html={heading} />
    </h1>

    {subheading && (
      <p
        class="text-lg sm:text-xl md:text-2xl text-muted-foreground max-w-3xl mx-auto leading-relaxed"
        data-care-field="subheading"
      >
        {subheading}
      </p>
    )}

    <!-- Scroll indicator -->
    <div class="mt-16 flex justify-center">
      <div class="flex flex-col items-center gap-2 text-muted-foreground/60">
        <span class="text-xs uppercase tracking-widest">Scroll</span>
        <div class="w-6 h-10 rounded-full border-2 border-current flex justify-center pt-2">
          <div class="w-1.5 h-3 bg-current rounded-full animate-bounce"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ profileContent, instanceId, defaultProfile }}>
  (() => {
    const root = document.getElementById(instanceId);
    if (!root || !profileContent || Object.keys(profileContent).length === 0) return;

    const apply = (profile) => {
      const data = profileContent[profile];
      if (!data) return;
      const headingNode = root.querySelector('[data-care-field="heading"]');
      const subheadingNode = root.querySelector('[data-care-field="subheading"]');
      if (headingNode && data.heading) headingNode.innerHTML = data.heading;
      if (subheadingNode && data.subheading) subheadingNode.textContent = data.subheading;
    };

    apply(document.documentElement.dataset.careProfile || defaultProfile);
    window.addEventListener('care-profile-change', (event) => {
      apply(event.detail?.profile || defaultProfile);
    });
  })();
</script>
