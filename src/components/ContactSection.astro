---
import { Icon } from 'astro-icon/components';

/**
 * ContactSection.astro - Contact information section
 * Displays contact details and call-to-action in a card layout
 */

interface Props {
  heading?: string;
  intro?: string;
  phoneLabel?: string;
  phoneHref?: string;
  address?: string;
}

const {
  heading = "Get in touch",
  intro = "Need to know more? Contact us today to discuss your needs.",
  phoneLabel = "[Your Phone]",
  phoneHref = "tel:[Your Phone]",
  address = "[Your City], [Your Region]"
} = Astro.props as Props;
---

<section class="bg-secondary/30 py-16 lg:py-20" id="contact">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Card Container -->
    <div class="bg-white rounded-2xl shadow-lg border border-border overflow-hidden">
      <!-- Header Section -->
      <div class="bg-primary px-6 py-8 sm:px-10 sm:py-10 text-center">
        <h2 class="text-2xl sm:text-3xl font-semibold text-white mb-2">{heading}</h2>
        <p class="text-white/80 text-sm sm:text-base">{intro}</p>
      </div>

      <!-- Content Section -->
      <div class="p-6 sm:p-10">
        <div class="grid sm:grid-cols-2 gap-6 sm:gap-8">
          <!-- Phone Card -->
          <a
            href={phoneHref}
            class="group flex flex-col items-center text-center p-6 rounded-xl bg-secondary/40 hover:bg-secondary/60 transition-colors border border-border"
          >
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-primary text-white mb-4 group-hover:scale-110 transition-transform">
              <Icon name="tabler:phone" class="h-6 w-6" />
            </div>
            <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-1">Phone</span>
            <span class="text-lg font-semibold text-primary">{phoneLabel}</span>
          </a>

          <!-- Address Card -->
          <div class="flex flex-col items-center text-center p-6 rounded-xl bg-secondary/40 border border-border">
            <div class="inline-flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary mb-4">
              <Icon name="tabler:map-pin" class="h-6 w-6" />
            </div>
            <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-1">Address</span>
            <span class="text-sm text-foreground">{address}</span>
          </div>
        </div>

        <!-- CTA Button -->
        <div class="mt-8 text-center">
          <a
            href={phoneHref}
            class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 text-base font-semibold text-white shadow-lg hover:bg-primary/90 hover:shadow-xl hover:-translate-y-0.5 transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            <Icon name="tabler:phone" class="h-5 w-5" />
            Call us now
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
