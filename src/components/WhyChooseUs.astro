---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Point {
  title: string;
  description: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  points?: Point[];
  imageSrc?: ImageMetadata;
  imageAlt?: string;
}

const {
  eyebrow = "Why choose us",
  heading = "[Your Value Proposition Headline]",
  intro =
    "[Describe what makes you different - your unique approach and why clients should choose you]",
  imageSrc,
  imageAlt = "[Your image description]",
  points = [
    {
      title: "[Differentiator 1]",
      description:
        "[Describe your first key differentiator - what sets you apart]",
    },
    {
      title: "[Differentiator 2]",
      description:
        "[Describe your second key differentiator - another reason to choose you]",
    },
    {
      title: "[Differentiator 3]",
      description:
        "[Describe your third key differentiator - complete your value proposition]",
    },
  ],
} = Astro.props as Props;
---

<section class="bg-secondary" id="why-us">
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16 grid gap-8 md:grid-cols-2 md:items-center"
  >
    <div class="space-y-4">
      {eyebrow && (
        <p class="text-sm font-semibold uppercase tracking-wide text-primary">
          {eyebrow}
        </p>
      )}
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-semibold text-foreground">
        {heading}
      </h2>
      <p class="text-sm sm:text-base text-muted-foreground">{intro}</p>

      <ul class="mt-4 space-y-3">
        {points.map((point) => (
          <li class="flex gap-3">
            <span
              class="mt-1 inline-flex h-6 w-6 items-center justify-center rounded-full bg-primary/10 text-primary"
            >
              <span class="text-xs font-bold">✓</span>
            </span>
            <div>
              <p class="text-sm font-medium text-foreground">{point.title}</p>
              {point.description && (
                <p class="text-sm text-muted-foreground">{point.description}</p>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>

    {imageSrc && (
      <div class="md:order-first">
        <div class="overflow-hidden rounded-xl border border-border bg-card shadow-sm">
          <Image src={imageSrc} alt={imageAlt} class="h-full w-full object-cover" loading="lazy" />
        </div>
      </div>
    )}
  </div>
</section>

