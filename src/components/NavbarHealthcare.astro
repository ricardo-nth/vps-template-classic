---
interface NavLink {
  label: string;
  href: string;
  active?: boolean;
}

interface Props {
  brandName?: string;
  brandHref?: string;
  navLinks?: NavLink[];
  ctaText?: string;
  ctaHref?: string;
}

const {
  brandName = "[Business Name]",
  brandHref = "/",
  navLinks = [
    { label: "About", href: "/about" },
    { label: "Services", href: "/services" },
    { label: "Our Facility", href: "/our-home" },
  ],
  ctaText = "Contact Us",
  ctaHref = "/contact",
} = Astro.props as Props;

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/' && currentPath === '/') return true;
  // Check if current path starts with href (for subpages) but ignore root href '/'
  if (href !== '/' && currentPath.startsWith(href)) return true;
  return false;
};

const calculatedLinks = navLinks.map(link => ({
  ...link,
  active: isActive(link.href)
}));
---

<header class="relative flex flex-wrap md:justify-start md:flex-nowrap z-50 w-full bg-nav-primary text-nav-primary-foreground shadow-sm">
  <nav class="relative max-w-6xl w-full mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Brand -->
      <a href={brandHref} class="flex items-center gap-2">
        <div class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-nav-secondary text-nav-secondary-foreground">
          <span class="text-lg font-semibold">U</span>
        </div>
        <span class="text-lg font-semibold tracking-tight">
          {brandName}
        </span>
      </a>

      <!-- Desktop navigation -->
      <div class="hidden md:flex items-center gap-8">
        <ul class="flex items-center gap-6 text-sm font-medium">
          {calculatedLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class={`border-b-2 pb-1 transition-colors hover:border-primary hover:text-primary ${
                  link.active 
                    ? "border-primary text-primary font-semibold" 
                    : "border-transparent text-nav-primary-foreground"
                }`}
              >
                {link.label}
              </a>
            </li>
          ))}

          <!-- Contact Mega Menu -->
          <li class="hs-dropdown [--strategy:static] md:[--strategy:absolute] [--adaptive:none] [--trigger:hover] relative">
            <button id="hs-mega-menu-contact" type="button" class="flex items-center text-nav-primary-foreground hover:text-primary font-medium transition-colors">
              Contact
              <svg class="ms-1 size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>

            <div class="hs-dropdown-menu transition-[opacity,margin] duration-[0.1ms] md:duration-[150ms] hs-dropdown-open:opacity-100 opacity-0 w-full md:w-[600px] hidden z-10 top-full start-0 md:start-auto md:end-0 mt-2 bg-white rounded-xl shadow-xl border border-[#B69F38]/20 overflow-hidden" role="menu" aria-orientation="vertical" aria-labelledby="hs-mega-menu-contact">
              <div class="grid md:grid-cols-2">
                <!-- Careers Section -->
                <div class="p-6 bg-[#F6F0D8]">
                  <a href="/careers" class="group block">
                    <div class="flex items-center gap-x-4 mb-4">
                      <div class="bg-white p-2 rounded-lg shadow-sm">
                        <svg class="size-6 text-[#365C1C]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                      </div>
                      <div>
                        <h3 class="font-serif font-bold text-[#365C1C] group-hover:text-[#B69F38] transition-colors">Join the Team</h3>
                        <p class="text-xs text-gray-600">Explore career opportunities</p>
                      </div>
                    </div>
                    <p class="text-sm text-gray-700 leading-relaxed mb-3">
                      We are always looking for compassionate individuals to join our family. View our current vacancies.
                    </p>
                    <span class="text-[#365C1C] text-sm font-medium inline-flex items-center gap-x-1 group-hover:gap-x-2 transition-all">
                      View Careers
                      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    </span>
                  </a>
                </div>

                <!-- Contact Options -->
                <div class="p-6 flex flex-col justify-center bg-white">
                  <span class="text-xs font-semibold text-[#B69F38] uppercase tracking-wider mb-4">Get in Touch</span>
                  <div class="space-y-4">
                    <a href="/contact" class="flex items-center gap-x-3 group">
                      <div class="bg-[#365C1C]/10 p-2 rounded-full text-[#365C1C] group-hover:bg-[#365C1C] group-hover:text-white transition-colors">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                      </div>
                      <span class="text-sm font-medium text-gray-800 group-hover:text-[#365C1C]">Send an Email</span>
                    </a>
                    <a href="tel:[Your Phone]" class="flex items-center gap-x-3 group">
                      <div class="bg-[#365C1C]/10 p-2 rounded-full text-[#365C1C] group-hover:bg-[#365C1C] group-hover:text-white transition-colors">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                      </div>
                      <span class="text-sm font-medium text-gray-800 group-hover:text-[#365C1C]">[Your Phone]</span>
                    </a>
                    <a href="/contact" class="flex items-center gap-x-3 group">
                      <div class="bg-[#365C1C]/10 p-2 rounded-full text-[#365C1C] group-hover:bg-[#365C1C] group-hover:text-white transition-colors">
                        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                      </div>
                      <span class="text-sm font-medium text-gray-800 group-hover:text-[#365C1C]">Visit our Office</span>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </li>
        </ul>

        {ctaText && (
          <a
            href={ctaHref}
            class="inline-flex items-center rounded-full bg-primary px-4 py-1.5 text-xs font-medium text-primary-foreground shadow-sm hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-primary focus-visible:ring-primary-foreground"
          >
            {ctaText}
          </a>
        )}
      </div>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="hs-collapse-toggle md:hidden inline-flex items-center justify-center rounded-md border border-nav-primary-foreground/40 p-2 text-nav-primary-foreground hover:bg-nav-primary-foreground/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-nav-primary-foreground"
        id="hs-navbar-header-floating-collapse"
        aria-expanded="false"
        aria-controls="hs-navbar-header-floating"
        data-hs-collapse="#hs-navbar-header-floating"
      >
        <span class="sr-only">Toggle navigation</span>
        <svg
          class="hs-collapse-open:hidden h-5 w-5"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" x2="21" y1="6" y2="6" />
          <line x1="3" x2="21" y1="12" y2="12" />
          <line x1="3" x2="21" y1="18" y2="18" />
        </svg>
        <svg
          class="hs-collapse-open:block hidden h-5 w-5"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile navigation -->
    <div id="hs-navbar-header-floating" class="hs-collapse hidden overflow-hidden transition-all duration-300 basis-full grow md:hidden absolute top-16 left-0 w-full bg-nav-primary shadow-md sm:static sm:shadow-none sm:w-auto sm:bg-transparent" aria-labelledby="hs-navbar-header-floating-collapse">
      <div class="flex flex-col gap-y-4 p-4 sm:p-0">
        <ul class="space-y-1 text-sm font-medium">
          {calculatedLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class={`flex items-center justify-between rounded-md px-3 py-2 hover:bg-primary/10 hover:text-primary ${
                  link.active ? "bg-primary/10 text-primary font-semibold" : "text-nav-primary-foreground"
                }`}
              >
                <span>{link.label}</span>
              </a>
            </li>
          ))}
          
          <!-- Mobile Contact Dropdown -->
          <li class="hs-collapse hidden w-full overflow-hidden transition-[height] duration-300" id="mobile-mega-menu">
             <!-- Placeholder for JS collapse if needed, but simpler to just list links for now -->
          </li>
          
          <li>
            <a href="/careers" class="flex items-center justify-between rounded-md px-3 py-2 hover:bg-primary/10 hover:text-primary text-nav-primary-foreground">
              <span>Careers</span>
            </a>
          </li>
          <li>
            <a href="/contact" class="flex items-center justify-between rounded-md px-3 py-2 hover:bg-primary/10 hover:text-primary text-nav-primary-foreground">
              <span>Contact</span>
            </a>
          </li>
        </ul>

        {ctaText && (
          <a
            href={ctaHref}
            class="inline-flex w-full items-center justify-center rounded-full bg-primary px-4 py-2 text-xs font-semibold text-primary-foreground hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-nav-primary-foreground"
          >
            {ctaText}
          </a>
        )}
      </div>
    </div>
  </nav>
</header>

