---
interface TeamMember {
  name: string;
  role: string;
  description: string;
  image: string;
  imageAlt?: string;
}

interface Props {
  heading?: string;
  intro?: string;
  members?: TeamMember[];
}

const {
  heading = "Meet Our Team",
  intro =
    "[Introduce your team - the people behind your business who make it special]",
  members = [
    {
      name: "[Team Member 1 Name]",
      role: "[Role/Title]",
      description:
        "[Brief bio - their experience and what they bring to the team]",
      image:
        "https://images.unsplash.com/photo-1535916707207-35f97e715e1b?auto=format&fit=crop&w=320&q=80",
      imageAlt: "[Team member 1 photo description]",
    },
    {
      name: "[Team Member 2 Name]",
      role: "[Role/Title]",
      description:
        "[Brief bio - their experience and what they bring to the team]",
      image:
        "https://images.unsplash.com/photo-1535916707207-35f97e715e1b?auto=format&fit=crop&w=320&q=80",
      imageAlt: "[Team member 2 photo description]",
    },
    {
      name: "[Team Member 3 Name]",
      role: "[Role/Title]",
      description:
        "[Brief bio - their experience and what they bring to the team]",
      image:
        "https://images.unsplash.com/photo-1530023367847-a683933f4172?auto=format&fit=crop&w=320&q=80",
      imageAlt: "[Team member 3 photo description]",
    },
  ],
} = Astro.props as Props;
---

<section class="bg-background" id="team">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="mx-auto mb-10 max-w-2xl text-center">
      <h2 class="text-2xl sm:text-3xl font-semibold text-foreground">{heading}</h2>
      <p class="mt-2 text-sm sm:text-base text-muted-foreground">{intro}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {members.map((member) => (
        <div class="flex flex-col rounded-xl border border-border bg-card p-5 shadow-sm">
          <div class="flex items-center gap-4">
            <img
              src={member.image}
              alt={member.imageAlt || member.name}
              class="h-16 w-16 rounded-full object-cover"
            />
            <div>
              <p class="text-sm font-semibold text-card-foreground">{member.name}</p>
              <p class="text-xs uppercase tracking-wide text-muted-foreground">{member.role}</p>
            </div>
          </div>

          <p class="mt-3 text-sm text-muted-foreground">{member.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

