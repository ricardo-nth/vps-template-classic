---
import { Icon } from 'astro-icon/components';
import { sharedContactConfig, siteConfig } from '@/config/site';

interface Props {
  brandName?: string;
  tagline?: string;
  address?: string;
  phoneLabel?: string;
  phoneHref?: string;
  emailLabel?: string;
  emailHref?: string;
}

const {
  brandName = siteConfig.name,
  tagline = siteConfig.description,
  address = sharedContactConfig.address,
  phoneLabel = sharedContactConfig.phoneLabel,
  phoneHref = sharedContactConfig.phoneHref,
  emailLabel = sharedContactConfig.emailLabel,
  emailHref = sharedContactConfig.emailHref,
} = Astro.props as Props;

const siteLinks = [
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
  { label: "Sitemap", href: "/sitemap-index.xml" },
];

const servicesLinks = [
  { label: "Residential Care", href: "/services/residential-care" },
  { label: "Transitional Care", href: "/transitional-care" },
  { label: "Wellbeing Support", href: "/wellbeing-support" },
  { label: "Our Facility", href: "/our-home" },
];
---

<footer class="bg-[#F6F0D8] text-[#365C1C] border-t border-[#B69F38]/20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">

      <!-- Brand Column -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-md bg-[#365C1C] text-white">
            <span class="text-xl font-serif font-bold">U</span>
          </div>
          <span class="text-xl font-serif font-bold tracking-tight text-[#365C1C]">
            {brandName}
          </span>
        </div>
        <p class="text-sm text-[#365C1C]/80 leading-relaxed">
          {tagline}
        </p>
      </div>

      <!-- Site Links Column -->
      <div>
        <h3 class="font-serif font-bold text-lg mb-4 text-[#B69F38]">Site Links</h3>
        <ul class="space-y-3">
          {siteLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium hover:text-[#B69F38] transition-colors inline-flex items-center gap-1"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="font-serif font-bold text-lg mb-4 text-[#B69F38]">Services</h3>
        <ul class="space-y-3">
          {servicesLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium hover:text-[#B69F38] transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-serif font-bold text-lg mb-4 text-[#B69F38]">Contact</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <Icon name="tabler:mail" class="size-5 text-[#B69F38] mt-0.5 shrink-0" />
            <a href={emailHref} class="hover:text-[#B69F38] transition-colors">{emailLabel}</a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="tabler:phone" class="size-5 text-[#B69F38] mt-0.5 shrink-0" />
            <a href={phoneHref} class="hover:text-[#B69F38] transition-colors">{phoneLabel}</a>
          </li>
          <li class="flex items-start gap-3">
            <Icon name="tabler:map-pin" class="size-5 text-[#B69F38] mt-0.5 shrink-0" />
            <span>{address}</span>
          </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-[#365C1C]/10 mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-[#365C1C]/60">
      <p>© {new Date().getFullYear()} {brandName}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-[#365C1C] transition-colors" aria-label="Privacy Policy (coming soon)">Privacy Policy</a>
        <a href="#" class="hover:text-[#365C1C] transition-colors" aria-label="Terms of Service (coming soon)">Terms of Service</a>
        <a href="#" class="hover:text-[#365C1C] transition-colors" aria-label="Cookie Policy (coming soon)">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
