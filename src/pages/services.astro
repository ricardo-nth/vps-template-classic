---
/**
 * services.astro - Services Overview Page
 * Lists all available services with links to detailed pages
 */

import SiteLayout from '../layouts/SiteLayout.astro';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import serviceHighlight from '@assets/images/service-highlight.jpg';
import wellbeingSupport from '@assets/images/wellbeing-support.jpg';
import facilityTour from '@assets/images/facility-tour.jpg';

const servicesEntry = await getEntry('classicServices', 'default');
const servicesDomEntry = await getEntry('classicServices', 'dom-care');
if (!servicesEntry) {
  throw new Error('Missing content entry: classicServices/default');
}
if (!servicesDomEntry) {
  throw new Error('Missing content entry: classicServices/dom-care');
}

const profiles = [
  { key: 'supported-living', content: servicesEntry.data },
  { key: 'dom-care', content: servicesDomEntry.data },
] as const;

// Map image keys to imported assets
const imageMap: Record<string, ImageMetadata> = {
  'service-1': serviceHighlight,
  'service-2': wellbeingSupport,
  'service-3': facilityTour,
};
---

<SiteLayout metadata={servicesEntry.data.metadata}>
  <div data-care-profile-switcher>
    {profiles.map(({ key, content }) => (
      <div data-care-profile-panel={key} class:list={{ hidden: key !== 'supported-living' }}>
        <!-- HERO SECTION -->
        <section class="relative py-24 lg:py-32 bg-primary overflow-hidden">
          <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-secondary/20 rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-accent/10 rounded-full blur-3xl"></div>

          <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-white leading-tight mb-8">
              {content.hero.heading}
            </h1>
            <p class="text-xl text-white/90 max-w-3xl mx-auto leading-relaxed">
              {content.hero.subheading}
            </p>
          </div>
        </section>

        <!-- SERVICES GRID -->
        <section class="py-20 bg-background">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            
            <!-- Section Intro -->
            <div class="max-w-3xl mx-auto text-center mb-16">
              <span class="text-accent font-serif italic text-xl mb-4 block">Comprehensive Care</span>
              <h2 class="font-serif text-4xl md:text-5xl text-primary mb-6">What We Offer</h2>
              <p class="text-lg text-muted-foreground leading-relaxed">
                We deliver structured care pathways with consistent standards, clear communication, and practical outcomes for adults, families, and professional referrers.
              </p>
            </div>

            <!-- Services Cards -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
              {content.services.map((service) => (
                <div class="group relative overflow-hidden rounded-2xl bg-white shadow-lg transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">

                  <!-- Image -->
                  <div class="aspect-w-16 aspect-h-9 h-64 overflow-hidden relative">
                    <Image
                      src={imageMap[service.imageKey] || serviceHighlight}
                      alt={service.imageAlt}
                      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-primary/80 via-primary/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-300"></div>
                  </div>

                  <!-- Content -->
                  <div class="p-8">
                    <h3 class="font-serif text-2xl text-primary mb-3">{service.title}</h3>
                    <p class="text-muted-foreground leading-relaxed mb-6">
                      {service.description}
                    </p>
                    <ul class="space-y-2 mb-6">
                      {service.features.map((feature) => (
                        <li class="flex items-center gap-2 text-sm text-foreground/80">
                          <span class="text-accent">✓</span> {feature}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      </div>
    ))}
  </div>
</SiteLayout>
