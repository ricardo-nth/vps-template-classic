---
import SiteLayout from '../layouts/SiteLayout.astro';

const metadata = {
  title: 'Contact Us - [Business Name]',
  description: 'Get in touch with [Business Name] to discuss your needs or schedule a visit.',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact [Business Name]',
  }
};
---

<SiteLayout metadata={metadata}>
  <div class="bg-secondary py-20">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-serif text-5xl text-primary mb-6">Get in Touch</h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        We are here to answer your questions and help you find the right solution.
      </p>
    </div>
  </div>

  <div class="py-20 max-w-6xl mx-auto px-4 grid lg:grid-cols-2 gap-16">
    <!-- Contact Info -->
    <div>
      <h2 class="font-serif text-3xl text-primary mb-8">Contact Information</h2>
      <div class="space-y-8">
        <div class="flex items-start gap-4">
          <div class="bg-primary/10 p-3 rounded-full text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Phone</h3>
            <p class="text-muted-foreground mb-1">[Your availability hours]</p>
            <a href="tel:[Your Phone]" class="text-xl text-primary font-medium hover:underline">[Your Phone]</a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="bg-primary/10 p-3 rounded-full text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Email</h3>
            <p class="text-muted-foreground mb-1">For general enquiries</p>
            <a href="mailto:[Your Email]" class="text-xl text-primary font-medium hover:underline">[Your Email]</a>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="bg-primary/10 p-3 rounded-full text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Location</h3>
            <address class="not-italic text-muted-foreground text-lg">
              [Business Name]<br/>
              [Your City], [Your Region]<br/>
              [Additional address info if needed]
            </address>
          </div>
        </div>
      </div>

      <!-- CTA for custom site -->
      <div class="mt-12 p-6 bg-secondary/50 rounded-2xl">
        <h3 class="font-serif text-xl text-primary mb-2">Need a Website Like This?</h3>
        <p class="text-muted-foreground mb-4">Get your own professional website built and hosted - you just provide content, we handle everything else.</p>
        <a
          href="https://vertexplatformsolutions.com/offers/healthcare-agencies"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors"
        >
          Get This Site Built For You
        </a>
      </div>
    </div>

    <!-- Form -->
    <div class="bg-white p-8 rounded-2xl shadow-lg border border-border">
      <h2 class="font-serif text-2xl text-primary mb-6">Send us a Message</h2>
      <form class="space-y-4">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="first-name" class="block text-sm font-medium text-foreground mb-1">First Name</label>
            <input type="text" id="first-name" class="w-full rounded-lg border-border bg-background px-4 py-2 focus:border-primary focus:ring-primary" />
          </div>
          <div>
            <label for="last-name" class="block text-sm font-medium text-foreground mb-1">Last Name</label>
            <input type="text" id="last-name" class="w-full rounded-lg border-border bg-background px-4 py-2 focus:border-primary focus:ring-primary" />
          </div>
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-foreground mb-1">Email Address</label>
          <input type="email" id="email" class="w-full rounded-lg border-border bg-background px-4 py-2 focus:border-primary focus:ring-primary" />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-foreground mb-1">How can we help?</label>
          <textarea id="message" rows="4" class="w-full rounded-lg border-border bg-background px-4 py-2 focus:border-primary focus:ring-primary"></textarea>
        </div>
        <button type="submit" class="w-full bg-primary text-white font-semibold py-3 rounded-lg hover:bg-primary/90 transition-colors">
          Send Message
        </button>
      </form>
    </div>
  </div>
</SiteLayout>
