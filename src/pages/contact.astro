---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getEntry } from 'astro:content';
import { Icon } from 'astro-icon/components';
import PageHero from '@components/PageHero.astro';
import FeedbackSection from '@components/FeedbackSection.astro';

const contactEntry = await getEntry('classicContact', 'default');
const contactDomEntry = await getEntry('classicContact', 'dom-care');
if (!contactEntry) {
  throw new Error('Missing content entry: classicContact/default');
}
if (!contactDomEntry) {
  throw new Error('Missing content entry: classicContact/dom-care');
}

const profiles = [
  { key: 'supported-living', content: contactEntry.data },
  { key: 'dom-care', content: contactDomEntry.data },
] as const;
---

<SiteLayout metadata={contactEntry.data.metadata}>
  <div data-care-profile-switcher>
    {profiles.map(({ key, content }) => (
      <div data-care-profile-panel={key} class:list={{ hidden: key !== 'supported-living' }}>
        <PageHero
          eyebrow={content.hero.eyebrow}
          heading={content.hero.heading}
          subheading={content.hero.subheading}
          profileContent={content.hero.profileContent}
        />

        <div class="py-20 max-w-6xl mx-auto px-4 grid lg:grid-cols-2 gap-16">
          <!-- Contact Info -->
          <div>
            <h2 class="font-serif text-3xl text-primary mb-8">Contact Information</h2>
            <div class="space-y-8">
              <div class="flex items-start gap-4">
                <div class="bg-primary/10 p-3 rounded-full text-primary">
                  <Icon name="tabler:phone" class="h-6 w-6" />
                </div>
                <div>
                  <h3 class="font-semibold text-lg">Phone</h3>
                  <p class="text-muted-foreground mb-1">{content.contactInfo.phoneAvailability}</p>
                  <a href={content.contactInfo.phoneHref} class="text-xl text-primary font-medium hover:underline">{content.contactInfo.phoneLabel}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="bg-primary/10 p-3 rounded-full text-primary">
                  <Icon name="tabler:mail" class="h-6 w-6" />
                </div>
                <div>
                  <h3 class="font-semibold text-lg">Email</h3>
                  <p class="text-muted-foreground mb-1">For general enquiries</p>
                  <a href={content.contactInfo.emailHref} class="text-xl text-primary font-medium hover:underline">{content.contactInfo.emailLabel}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="bg-primary/10 p-3 rounded-full text-primary">
                  <Icon name="tabler:map-pin" class="h-6 w-6" />
                </div>
                <div>
                  <h3 class="font-semibold text-lg">Location</h3>
                  <address class="not-italic text-muted-foreground text-lg whitespace-pre-line">
                    {content.contactInfo.address}
                  </address>
                </div>
              </div>
            </div>

            <!-- CTA for custom site -->
            <div class="mt-12 p-6 bg-secondary/50 rounded-2xl">
              <h3 class="font-serif text-xl text-primary mb-2">Need a Website Like This?</h3>
              <p class="text-muted-foreground mb-4">Get your own professional website built and hosted - you just provide content, we handle everything else.</p>
              <a
                href="https://vertexplatformsolutions.com/offers/healthcare-agencies"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors"
              >
                Get This Site Built For You
              </a>
            </div>
          </div>

          <!-- Form -->
          <div class="bg-white p-8 rounded-2xl shadow-lg border border-border">
            <h2 class="font-serif text-2xl text-primary mb-6">Send us a Message</h2>
            <form class="space-y-4">
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-foreground mb-1">First Name</label>
                  <input type="text" id="first-name" name="first-name" autocomplete="given-name" required class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
                </div>
                <div>
                  <label for="last-name" class="block text-sm font-medium text-foreground mb-1">Last Name</label>
                  <input type="text" id="last-name" name="last-name" autocomplete="family-name" required class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-foreground mb-1">Email Address</label>
                <input type="email" id="email" name="email" autocomplete="email" required class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" />
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-foreground mb-1">How can we help?</label>
                <textarea id="message" name="message" rows="4" required class="w-full rounded-lg border border-border bg-background px-4 py-2 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-y"></textarea>
              </div>
              <button type="submit" class="w-full bg-primary text-white font-semibold py-3 rounded-lg hover:bg-primary/90 transition-colors">
                Send Message
              </button>
            </form>
          </div>
        </div>

        <FeedbackSection
          heading={content.feedbackSection.heading}
          intro={content.feedbackSection.intro}
          compliment={content.feedbackSection.compliment}
          complaint={content.feedbackSection.complaint}
          cqcNote={content.feedbackSection.cqcNote}
          cqcLinkText={content.feedbackSection.cqcLinkText}
          cqcLinkHref={content.feedbackSection.cqcLinkHref}
        />
      </div>
    ))}
  </div>
</SiteLayout>
