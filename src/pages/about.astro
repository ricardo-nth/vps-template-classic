---
import SiteLayout from '../layouts/SiteLayout.astro';

const metadata = {
  title: 'About Us - [Business Name]',
  description: '[Your about page description - who you are and what makes you different]',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About [Business Name]',
  }
};
---

<SiteLayout metadata={metadata}>

  <!-- 1. HERO SECTION: IMPACTFUL & MINIMALIST -->
  <section class="relative py-24 lg:py-32 bg-[#F6F0D8] overflow-hidden">
    <!-- Organic background shape decoration -->
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 bg-[#B69F38]/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-80 h-80 bg-[#365C1C]/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <h4 class="text-[#B69F38] font-bold tracking-widest uppercase text-sm mb-6">Our Purpose</h4>
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl text-[#365C1C] leading-[1.1] mb-8">
          [Your About Headline] <br class="hidden md:block" />
          <span class="italic text-[#B69F38]">[Your Emphasis Line]</span>
        </h1>
        <p class="text-xl text-[#365C1C]/80 max-w-2xl leading-relaxed">
          [Your about intro - describe your mission and what drives your business]
        </p>
      </div>
    </div>
  </section>

  <!-- 2. THE NARRATIVE: FOUNDERS' STORY (Magazine Style Layout) -->
  <section class="py-20 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-12 gap-12 items-center">

        <!-- Image Side (Offset Grid) -->
        <div class="lg:col-span-5 relative">
          <div class="relative z-10 rounded-none overflow-hidden shadow-2xl aspect-[3/4] bg-gray-100">
             <img
               src="https://images.unsplash.com/photo-1556761175-5973dc0f32e7?q=80&w=1932&auto=format&fit=crop"
               alt="[Your team or founder image]"
               class="w-full h-full object-cover"
             />
          </div>
          <!-- Decorative border frame -->
          <div class="absolute top-8 -right-8 w-full h-full border-2 border-[#B69F38] -z-0 hidden md:block"></div>
        </div>

        <!-- Text Side -->
        <div class="lg:col-span-7 lg:pl-12">
          <h2 class="font-serif text-4xl md:text-5xl text-[#365C1C] mb-8">[Your Story Headline]</h2>

          <div class="prose prose-lg text-gray-600 leading-relaxed space-y-6">
            <p>
              [Your story paragraph 1 - introduce your founders or team and their background]
            </p>
            <p>
              [Your story paragraph 2 - describe the problem you saw and why you started this business]
            </p>
            <p>
              [Your story paragraph 3 - explain your approach and what makes you different]
            </p>

            <blockquote class="border-l-4 border-[#B69F38] pl-6 my-8 italic text-[#365C1C] text-xl">
              "[Your founder quote - what drives you and your vision for the future]"
            </blockquote>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 3. CORE PHILOSOPHY: BESPOKE CARDS -->
  <section class="py-24 bg-[#365C1C] text-white relative overflow-hidden">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-5 bg-[url('https://www.transparenttextures.com/patterns/noise-lines.png')]"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-20">
        <h2 class="font-serif text-4xl md:text-5xl mb-6">Our Approach</h2>
        <p class="text-[#F6F0D8]/80 text-lg max-w-2xl mx-auto">
          [Describe your approach in one or two sentences]
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Card 1 -->
        <div class="group p-8 border border-[#F6F0D8]/20 rounded-xl hover:bg-[#F6F0D8] hover:text-[#365C1C] transition-all duration-500 ease-out cursor-default">
          <div class="h-12 w-12 mb-6 text-[#B69F38] group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl mb-4 group-hover:text-[#365C1C]">[Value 1]</h3>
          <p class="text-[#F6F0D8]/70 leading-relaxed group-hover:text-[#365C1C]/80">
            [Description of your first core value or approach]
          </p>
        </div>

        <!-- Card 2 -->
        <div class="group p-8 border border-[#F6F0D8]/20 rounded-xl hover:bg-[#F6F0D8] hover:text-[#365C1C] transition-all duration-500 ease-out cursor-default">
          <div class="h-12 w-12 mb-6 text-[#B69F38] group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl mb-4 group-hover:text-[#365C1C]">[Value 2]</h3>
          <p class="text-[#F6F0D8]/70 leading-relaxed group-hover:text-[#365C1C]/80">
            [Description of your second core value or approach]
          </p>
        </div>

        <!-- Card 3 -->
        <div class="group p-8 border border-[#F6F0D8]/20 rounded-xl hover:bg-[#F6F0D8] hover:text-[#365C1C] transition-all duration-500 ease-out cursor-default">
          <div class="h-12 w-12 mb-6 text-[#B69F38] group-hover:scale-110 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-full h-full">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
            </svg>
          </div>
          <h3 class="font-serif text-2xl mb-4 group-hover:text-[#365C1C]">[Value 3]</h3>
          <p class="text-[#F6F0D8]/70 leading-relaxed group-hover:text-[#365C1C]/80">
            [Description of your third core value or approach]
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. VALUES & FUTURE -->
  <section class="py-24 bg-[#F6F0D8]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:text-center max-w-3xl mx-auto mb-16">
        <h2 class="font-serif text-4xl text-[#365C1C] mb-6">Our Vision for the Future</h2>
        <p class="text-lg text-[#365C1C]/80">
          [Describe your vision and future plans]
        </p>
      </div>

      <!-- Asymmetrical Layout -->
      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white p-10 rounded-2xl shadow-sm border-l-4 border-[#B69F38]">
          <h3 class="font-serif text-2xl text-[#365C1C] mb-4">[Commitment 1]</h3>
          <p class="text-gray-600 leading-relaxed">
            [Description of your first commitment or standard]
          </p>
        </div>
        <div class="bg-white p-10 rounded-2xl shadow-sm border-l-4 border-[#365C1C]">
          <h3 class="font-serif text-2xl text-[#365C1C] mb-4">[Commitment 2]</h3>
          <p class="text-gray-600 leading-relaxed">
            [Description of your second commitment or standard]
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. CTA -->
  <section class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-serif text-5xl text-[#365C1C] mb-8">[Your CTA Headline]</h2>
      <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
        [Your CTA description - encourage visitors to take the next step]
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-white bg-[#365C1C] rounded-full hover:bg-[#2a4715] transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1">
          Contact Us
        </a>
        <a href="https://vertexplatformsolutions.com/offers/healthcare-agencies" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-8 py-4 text-base font-bold text-[#365C1C] bg-[#F6F0D8] rounded-full hover:bg-[#eaddb5] transition-all duration-300">
          Get This Site Built For You
        </a>
      </div>
    </div>
  </section>

</SiteLayout>
