---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import PageHero from '@components/PageHero.astro';
import teamPortrait from '@assets/images/team-portrait.jpg';

const aboutEntry = await getEntry('classicAbout', 'default');
const aboutDomEntry = await getEntry('classicAbout', 'dom-care');
if (!aboutEntry) {
  throw new Error('Missing content entry: classicAbout/default');
}
if (!aboutDomEntry) {
  throw new Error('Missing content entry: classicAbout/dom-care');
}

const profiles = [
  { key: 'supported-living', content: aboutEntry.data },
  { key: 'dom-care', content: aboutDomEntry.data },
] as const;
---

<SiteLayout metadata={aboutEntry.data.metadata}>
  <div data-care-profile-switcher>
    {profiles.map(({ key, content }) => (
      <div data-care-profile-panel={key} class:list={{ hidden: key !== 'supported-living' }}>
        <PageHero
          eyebrow={content.hero.eyebrow}
          heading={content.hero.heading}
          subheading={content.hero.subheading}
        />

        <section class="py-20 bg-white">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-12 lg:grid-cols-2 items-center">
            <div>
              <h2 class="font-serif text-4xl text-primary mb-6">{content.story.heading}</h2>
              <div class="space-y-4 text-muted-foreground leading-relaxed">
                {content.story.paragraphs.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
              <blockquote class="mt-8 border-l-4 border-accent pl-6 italic text-primary text-lg">
                "{content.story.quote}"
              </blockquote>
            </div>

            <div class="rounded-2xl overflow-hidden shadow-xl border border-border">
              <Image
                src={teamPortrait}
                alt={content.story.imageAlt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </section>

        <section class="py-20 bg-primary text-white">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-12">
              <h2 class="font-serif text-4xl mb-4">{content.valuesSection.heading}</h2>
              <p class="text-white/85">{content.valuesSection.intro}</p>
            </div>

            <div class="grid gap-6 md:grid-cols-2">
              {content.values.map((value) => (
                <div class="rounded-xl border border-white/20 p-8 bg-white/5">
                  <h3 class="font-serif text-2xl mb-3">{value.title}</h3>
                  <p class="text-white/80 leading-relaxed">{value.description}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="py-20 bg-secondary/50">
          <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="font-serif text-4xl text-primary mb-6">{content.ctaSection.heading}</h2>
            <p class="text-muted-foreground mb-8">{content.ctaSection.intro}</p>
            <a href={content.ctaSection.buttonHref} class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors shadow-lg">
              {content.ctaSection.buttonText}
            </a>
          </div>
        </section>
      </div>
    ))}
  </div>
</SiteLayout>
