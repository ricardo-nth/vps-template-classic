---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PageHero from '@components/PageHero.astro';
import serviceGeneral from '@assets/images/service-general.jpg';
import facilityTour from '@assets/images/facility-tour.jpg';
import featuredSection from '@assets/images/featured-section.jpg';

const ourHomeEntry = await getEntry('classicOurHome', 'default');
const ourHomeDomEntry = await getEntry('classicOurHome', 'dom-care');
if (!ourHomeEntry) {
  throw new Error('Missing content entry: classicOurHome/default');
}
if (!ourHomeDomEntry) {
  throw new Error('Missing content entry: classicOurHome/dom-care');
}

const profiles = [
  { key: 'supported-living', content: ourHomeEntry.data },
  { key: 'dom-care', content: ourHomeDomEntry.data },
] as const;

const imageMap: Record<string, ImageMetadata> = {
  'service-general': serviceGeneral,
  'facility-tour': facilityTour,
  'featured-section': featuredSection,
};
---

<SiteLayout metadata={ourHomeEntry.data.metadata}>
  <div data-care-profile-switcher>
    {profiles.map(({ key, content }) => (
      <div data-care-profile-panel={key} class:list={{ hidden: key !== 'supported-living' }}>
        <PageHero
          eyebrow="Our Home"
          heading={content.hero.heading}
          subheading={content.hero.subheading}
          profileContent={content.hero.profileContent}
        />

        <section class="py-16 bg-background">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center">
            <div>
              <h2 class="font-serif text-4xl text-primary mb-6">{content.overview.heading}</h2>
              <p class="text-muted-foreground leading-relaxed mb-6">{content.overview.description}</p>
              <ul class="grid sm:grid-cols-2 gap-3">
                {content.overview.features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-muted-foreground">
                    <span class="text-accent">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            <div class="rounded-2xl overflow-hidden shadow-xl border border-border">
              <Image
                src={imageMap[content.overview.imageKey] || serviceGeneral}
                alt={content.overview.imageAlt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </section>

        <section class="py-16 bg-white border-y border-border">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center max-w-3xl mx-auto mb-10">
              <h2 class="font-serif text-4xl text-primary mb-4">{content.spacesSection.heading}</h2>
              <p class="text-muted-foreground">{content.spacesSection.intro}</p>
            </div>

            <div class="grid gap-8 md:grid-cols-3">
              {content.spacesSection.spaces.map((space) => (
                <div class="rounded-xl overflow-hidden border border-border shadow-sm bg-background">
                  <Image
                    src={imageMap[space.imageKey] || facilityTour}
                    alt={space.imageAlt}
                    class="h-52 w-full object-cover"
                    loading="lazy"
                  />
                  <div class="p-6">
                    <h3 class="font-serif text-2xl text-primary mb-2">{space.name}</h3>
                    <p class="text-sm text-muted-foreground">{space.description}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="py-16 bg-background">
          <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-10 md:grid-cols-2">
            <div>
              <h2 class="font-serif text-4xl text-primary mb-4">{content.locationSection.heading}</h2>
              <p class="text-muted-foreground mb-6">{content.locationSection.description}</p>
              <div class="space-y-4">
                {content.locationSection.points.map((point) => (
                  <div>
                    <h3 class="font-semibold text-foreground">{point.title}</h3>
                    <p class="text-sm text-muted-foreground">{point.description}</p>
                  </div>
                ))}
              </div>
            </div>
            <div class="rounded-2xl border border-border bg-secondary/40 p-8 flex flex-col justify-center">
              <p class="text-muted-foreground mb-6">Visit planning is available for families and professionals. Contact our team to arrange a suitable time.</p>
              <a href={content.locationSection.ctaHref} class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors w-fit">
                {content.locationSection.ctaText}
              </a>
            </div>
          </div>
        </section>

        <section class="py-16 bg-secondary/50">
          <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="font-serif text-4xl text-primary mb-6">{content.ctaSection.heading}</h2>
            <p class="text-muted-foreground mb-8">{content.ctaSection.description}</p>
            <a href={content.ctaSection.primaryHref} class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors shadow-lg">
              {content.ctaSection.primaryText}
            </a>
          </div>
        </section>
      </div>
    ))}
  </div>
</SiteLayout>
