---
import SiteLayout from '../layouts/SiteLayout.astro';

const metadata = {
  title: 'Our Facility - [Business Name]',
  description: '[Describe your facility or location - what makes it special and what visitors can expect]',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'Place',
    name: '[Business Name] Facility',
    amenityFeature: [
      { '@type': 'LocationFeatureSpecification', name: '[Feature 1]', value: true },
      { '@type': 'LocationFeatureSpecification', name: '[Feature 2]', value: true },
      { '@type': 'LocationFeatureSpecification', name: '[Feature 3]', value: true }
    ]
  }
};
---

<SiteLayout metadata={metadata}>
  <!-- Hero -->
  <div class="relative bg-secondary py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="relative max-w-6xl mx-auto px-4 text-center">
      <span class="block text-accent font-serif text-xl mb-4">[Eyebrow Text]</span>
      <h1 class="font-serif text-5xl md:text-6xl text-primary mb-6">[Your Facility Headline]</h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        [Describe your facility and what makes it special]
      </p>
    </div>
  </div>

  <!-- Property Overview -->
  <div class="py-20 max-w-6xl mx-auto px-4">
    <div class="grid lg:grid-cols-2 gap-16 items-center mb-24">
      <div class="relative rounded-2xl overflow-hidden shadow-2xl group">
        <img
          src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?q=80&w=2070&auto=format&fit=crop"
          alt="[Your facility image]"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/70 to-transparent p-8">
          <span class="text-white font-serif text-2xl">[Image Caption]</span>
        </div>
      </div>
      <div>
        <h2 class="font-serif text-4xl text-primary mb-6">[Section Headline]</h2>
        <p class="text-muted-foreground text-lg mb-6 leading-relaxed">
          [Describe what makes your facility unique and the experience visitors can expect]
        </p>
        <ul class="grid sm:grid-cols-2 gap-4">
          {[
            "[Feature 1]",
            "[Feature 2]",
            "[Feature 3]",
            "[Feature 4]",
            "[Feature 5]",
            "[Feature 6]"
          ].map(feature => (
            <li class="flex items-center gap-3 text-foreground">
              <span class="h-6 w-6 rounded-full bg-secondary flex items-center justify-center text-primary text-xs">✓</span>
              {feature}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Room/Space Tour -->
    <div class="mb-24">
      <div class="text-center mb-16">
        <h2 class="font-serif text-4xl text-primary mb-4">[Spaces Section Headline]</h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">[Describe the spaces in your facility]</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Space 1 -->
        <div class="bg-white rounded-xl overflow-hidden shadow-lg border border-border hover:shadow-xl transition-all">
          <div class="h-64 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?q=80&w=2058&auto=format&fit=crop"
              alt="[Space 1]"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6">
            <h3 class="font-serif text-xl text-primary mb-2">[Space 1 Name]</h3>
            <p class="text-sm text-muted-foreground mb-4">[Space 1 description]</p>
          </div>
        </div>

        <!-- Space 2 -->
        <div class="bg-white rounded-xl overflow-hidden shadow-lg border border-border hover:shadow-xl transition-all">
          <div class="h-64 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?q=80&w=2070&auto=format&fit=crop"
              alt="[Space 2]"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6">
            <h3 class="font-serif text-xl text-primary mb-2">[Space 2 Name]</h3>
            <p class="text-sm text-muted-foreground mb-4">[Space 2 description]</p>
          </div>
        </div>

        <!-- Space 3 -->
        <div class="bg-white rounded-xl overflow-hidden shadow-lg border border-border hover:shadow-xl transition-all">
          <div class="h-64 overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1560185007-cde436f6a4d0?q=80&w=2070&auto=format&fit=crop"
              alt="[Space 3]"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-6">
            <h3 class="font-serif text-xl text-primary mb-2">[Space 3 Name]</h3>
            <p class="text-sm text-muted-foreground mb-4">[Space 3 description]</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Facilities Gallery -->
    <div class="bg-secondary/30 rounded-3xl p-8 md:p-12">
      <h2 class="font-serif text-3xl text-primary mb-8 text-center">[Gallery Section Headline]</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="col-span-2 row-span-2 rounded-xl overflow-hidden h-full shadow-md">
          <img
            src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?q=80&w=2070&auto=format&fit=crop"
            alt="[Gallery image 1]"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md h-48 md:h-auto">
          <img
            src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?q=80&w=2058&auto=format&fit=crop"
            alt="[Gallery image 2]"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md h-48 md:h-auto">
          <img
            src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?q=80&w=2070&auto=format&fit=crop"
            alt="[Gallery image 3]"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="col-span-2 rounded-xl overflow-hidden shadow-md h-48 md:h-auto">
          <img
            src="https://images.unsplash.com/photo-1560185007-cde436f6a4d0?q=80&w=2070&auto=format&fit=crop"
            alt="[Gallery image 4]"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>

  <!-- Local Area -->
  <div class="bg-white py-20 border-t border-border">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <span class="text-accent font-semibold tracking-wider uppercase text-sm">Location</span>
          <h2 class="font-serif text-4xl text-primary mb-6">[Location Section Headline]</h2>
          <p class="text-muted-foreground mb-6">
            [Describe your location and its benefits]
          </p>
          <div class="space-y-4">
            <div class="flex gap-4">
              <div class="bg-secondary p-3 rounded-full h-fit">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <div>
                <h4 class="font-semibold text-foreground">[Location Feature 1]</h4>
                <p class="text-sm text-muted-foreground">[Description]</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="bg-secondary p-3 rounded-full h-fit">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
              </div>
              <div>
                <h4 class="font-semibold text-foreground">[Location Feature 2]</h4>
                <p class="text-sm text-muted-foreground">[Description]</p>
              </div>
            </div>
          </div>
        </div>
        <div class="h-96 bg-secondary rounded-2xl overflow-hidden shadow-inner flex items-center justify-center relative">
           <!-- Placeholder for Map -->
           <div class="relative z-10 bg-white p-6 rounded-xl shadow-lg text-center max-w-xs">
             <h3 class="font-serif text-xl text-primary mb-2">[CTA Headline]</h3>
             <p class="text-sm text-muted-foreground mb-4">[CTA description]</p>
             <a href="/contact" class="inline-block bg-primary text-white px-6 py-2 rounded-full text-sm hover:bg-primary/90 transition-colors">Contact Us</a>
           </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="py-16 bg-secondary/50">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-serif text-3xl text-primary mb-4">[CTA Headline]</h2>
      <p class="text-muted-foreground mb-8">[CTA description - encourage visitors to take action]</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors shadow-lg">
          Contact Us
        </a>
        <a href="https://vertexplatformsolutions.com/offers/healthcare-agencies" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-primary bg-white border-2 border-primary rounded-full hover:bg-primary/5 transition-colors shadow-lg">
          Get This Site Built For You
        </a>
      </div>
    </div>
  </div>
</SiteLayout>
