---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getEntry } from 'astro:content';
import PageHero from '@components/PageHero.astro';

const wellbeingEntry = await getEntry('classicWellbeingSupport', 'default');
const wellbeingDomEntry = await getEntry('classicWellbeingSupport', 'dom-care');
if (!wellbeingEntry) {
  throw new Error('Missing content entry: classicWellbeingSupport/default');
}
if (!wellbeingDomEntry) {
  throw new Error('Missing content entry: classicWellbeingSupport/dom-care');
}

const profiles = [
  { key: 'supported-living', content: wellbeingEntry.data },
  { key: 'dom-care', content: wellbeingDomEntry.data },
] as const;
---

<SiteLayout metadata={wellbeingEntry.data.metadata}>
  <div data-care-profile-switcher>
    {profiles.map(({ key, content }) => (
      <div data-care-profile-panel={key} class:list={{ hidden: key !== 'supported-living' }}>
        <PageHero
          eyebrow="Wellbeing Support"
          heading={content.hero.heading}
          subheading={content.hero.subheading}
          profileContent={content.hero.profileContent}
        />

        <section class="py-16 bg-white">
          <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="font-serif text-4xl text-primary mb-6">{content.overview.heading}</h2>
            <p class="text-muted-foreground leading-relaxed">{content.overview.description}</p>
          </div>
        </section>

        <section class="py-16 bg-background border-y border-border">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-3 gap-6">
            {content.features.map((feature) => (
              <article class="rounded-xl border border-border bg-card p-8">
                <h3 class="font-serif text-2xl text-primary mb-3">{feature.title}</h3>
                <p class="text-muted-foreground text-sm leading-relaxed">{feature.description}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="py-16 bg-primary text-white">
          <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h2 class="font-serif text-4xl mb-4">{content.outcomesSection.heading}</h2>
            <p class="text-white/85 max-w-3xl mx-auto mb-8">{content.outcomesSection.description}</p>
            <div class="grid gap-3 md:grid-cols-3 text-left">
              {content.outcomesSection.outcomes.map((outcome) => (
                <div class="rounded-lg border border-white/20 p-4 bg-white/5 text-sm">{outcome}</div>
              ))}
            </div>
          </div>
        </section>

        <section class="py-16 bg-secondary/50">
          <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="font-serif text-4xl text-primary mb-6">{content.ctaSection.heading}</h2>
            <p class="text-muted-foreground mb-8">{content.ctaSection.description}</p>
            <a href={content.ctaSection.primaryHref} class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors shadow-lg">
              {content.ctaSection.primaryText}
            </a>
          </div>
        </section>
      </div>
    ))}
  </div>
</SiteLayout>
