---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getEntry } from 'astro:content';
import PageHero from '@components/PageHero.astro';

const careersEntry = await getEntry('classicCareers', 'default');
const careersDomEntry = await getEntry('classicCareers', 'dom-care');
if (!careersEntry) {
  throw new Error('Missing content entry: classicCareers/default');
}
if (!careersDomEntry) {
  throw new Error('Missing content entry: classicCareers/dom-care');
}

const profiles = [
  { key: 'supported-living', content: careersEntry.data },
  { key: 'dom-care', content: careersDomEntry.data },
] as const;
---

<SiteLayout metadata={careersEntry.data.metadata}>
  <div data-care-profile-switcher>
    {profiles.map(({ key, content }) => (
      <div data-care-profile-panel={key} class:list={{ hidden: key !== 'supported-living' }}>
        <PageHero
          eyebrow={content.hero.eyebrow}
          heading={content.hero.heading}
          subheading={content.hero.subheading}
          profileContent={content.hero.profileContent}
        />

        <section class="py-20 max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-16">
          <div>
            <h2 class="font-serif text-3xl text-primary mb-6">{content.benefitsHeading}</h2>
            <ul class="space-y-4 mb-8">
              {content.benefits.map((benefit) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent mt-1">✓</span>
                  <div>
                    <strong class="block text-foreground">{benefit.title}</strong>
                    <span class="text-muted-foreground">{benefit.description}</span>
                  </div>
                </li>
              ))}
            </ul>

            <div class="mt-8 p-6 bg-secondary/50 rounded-2xl">
              <h3 class="font-serif text-xl text-primary mb-2">Need a Website Like This?</h3>
              <p class="text-muted-foreground mb-4">Get your own professional website built and hosted - you just provide content, we handle everything else.</p>
              <a
                href="https://vertexplatformsolutions.com/offers/healthcare-agencies"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors"
              >
                Get This Site Built For You
              </a>
            </div>
          </div>

          <div class="bg-white p-8 rounded-2xl shadow-lg border border-border">
            <h3 class="font-serif text-2xl text-primary mb-6">{content.vacanciesHeading}</h3>
            <div class="space-y-6">
              {content.vacancies.map((vacancy) => (
                <div class="border-b border-border pb-4 last:border-b-0 last:pb-0">
                  <h4 class="font-semibold text-lg">{vacancy.title}</h4>
                  <p class="text-sm text-muted-foreground mb-2">{vacancy.employmentType} - {vacancy.location}</p>
                  <a href={`mailto:${vacancy.applyEmail}`} class="text-primary text-sm font-medium hover:underline">Apply Now &rarr;</a>
                </div>
              ))}
            </div>

            <div class="mt-8 pt-6 border-t border-border">
              <p class="text-sm text-muted-foreground">{content.fallbackCopy}</p>
            </div>
          </div>
        </section>
      </div>
    ))}
  </div>
</SiteLayout>
