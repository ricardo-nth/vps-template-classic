---
import SiteLayout from '../layouts/SiteLayout.astro';

const metadata = {
  title: 'Careers - [Business Name]',
  description: 'Join our team of dedicated professionals. Rewarding careers with [Business Name].',
  schema: {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Careers at [Business Name]',
  }
};
---

<SiteLayout metadata={metadata}>
  <div class="bg-secondary py-20">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="font-serif text-5xl text-primary mb-6">Join Our Team</h1>
      <p class="text-xl text-muted-foreground max-w-3xl mx-auto">
        Make a real difference every day. We are looking for dedicated individuals to join our growing team.
      </p>
    </div>
  </div>

  <div class="py-20 max-w-6xl mx-auto px-4 grid md:grid-cols-2 gap-16">
    <div>
      <h2 class="font-serif text-3xl text-primary mb-6">Why Work With Us?</h2>
      <ul class="space-y-4 mb-8">
        <li class="flex items-start gap-3">
          <span class="text-accent mt-1">✓</span>
          <div>
            <strong class="block text-foreground">[Benefit 1 Title]</strong>
            <span class="text-muted-foreground">[Benefit 1 description]</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-accent mt-1">✓</span>
          <div>
            <strong class="block text-foreground">[Benefit 2 Title]</strong>
            <span class="text-muted-foreground">[Benefit 2 description]</span>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-accent mt-1">✓</span>
          <div>
            <strong class="block text-foreground">[Benefit 3 Title]</strong>
            <span class="text-muted-foreground">[Benefit 3 description]</span>
          </div>
        </li>
      </ul>

      <!-- CTA for custom site -->
      <div class="mt-8 p-6 bg-secondary/50 rounded-2xl">
        <h3 class="font-serif text-xl text-primary mb-2">Need a Website Like This?</h3>
        <p class="text-muted-foreground mb-4">Get your own professional website built and hosted - you just provide content, we handle everything else.</p>
        <a
          href="https://vertexplatformsolutions.com/offers/healthcare-agencies"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center justify-center px-6 py-3 text-sm font-semibold text-white bg-primary rounded-full hover:bg-primary/90 transition-colors"
        >
          Get This Site Built For You
        </a>
      </div>
    </div>

    <div class="bg-white p-8 rounded-2xl shadow-lg border border-border">
      <h3 class="font-serif text-2xl text-primary mb-6">Current Vacancies</h3>
      <div class="space-y-6">
        <div class="border-b border-border pb-4">
          <h4 class="font-semibold text-lg">[Job Title 1]</h4>
          <p class="text-sm text-muted-foreground mb-2">[Employment Type] - [Location]</p>
          <a href="mailto:[email]@yourdomain.co.uk" class="text-primary text-sm font-medium hover:underline">Apply Now &rarr;</a>
        </div>
        <div class="border-b border-border pb-4">
          <h4 class="font-semibold text-lg">[Job Title 2]</h4>
          <p class="text-sm text-muted-foreground mb-2">[Employment Type] - [Location]</p>
          <a href="mailto:[email]@yourdomain.co.uk" class="text-primary text-sm font-medium hover:underline">Apply Now &rarr;</a>
        </div>
        <div class="pb-4">
          <h4 class="font-semibold text-lg">[Job Title 3]</h4>
          <p class="text-sm text-muted-foreground mb-2">[Employment Type] - [Location]</p>
          <a href="mailto:[email]@yourdomain.co.uk" class="text-primary text-sm font-medium hover:underline">Apply Now &rarr;</a>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-border">
        <p class="text-sm text-muted-foreground">
          Don't see a role that fits? Send your CV to <a href="mailto:[email]@yourdomain.co.uk" class="text-primary font-medium hover:underline">[email]@yourdomain.co.uk</a> and we'll keep you in mind for future opportunities.
        </p>
      </div>
    </div>
  </div>
</SiteLayout>
