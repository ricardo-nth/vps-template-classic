---
interface TeamMember {
  name: string;
  role: string;
  description: string;
  image: string;
  imageAlt?: string;
}

interface Props {
  heading?: string;
  intro?: string;
  members?: TeamMember[];
}

const {
  heading = "Your care team",
  intro =
    "Introduce a few key faces to build trust. Swap the names, roles and bios with your own.",
  members = [
    {
      name: "Dr. Amina Patel",
      role: "Clinical Lead",
      description:
        "Oversees complex care plans and works closely with GPs and hospital teams.",
      image:
        "https://images.unsplash.com/photo-1535916707207-35f97e715e1b?auto=format&fit=crop&w=320&q=80",
      imageAlt: "Portrait of a smiling doctor",
    },
    {
      name: "James Miller",
      role: "Registered Nurse",
      description:
        "Supports people with medication, dressings and symptom management at home.",
      image:
        "https://images.unsplash.com/photo-1535916707207-35f97e715e1b?auto=format&fit=crop&w=320&q=80",
      imageAlt: "Portrait of a nurse",
    },
    {
      name: "Grace Okafor",
      role: "Care Coordinator",
      description:
        "Your first point of contact for visit schedules, reviews and day-to-day questions.",
      image:
        "https://images.unsplash.com/photo-1530023367847-a683933f4172?auto=format&fit=crop&w=320&q=80",
      imageAlt: "Portrait of a care coordinator",
    },
  ],
} = Astro.props as Props;
---

<section class="bg-background" id="team">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="mx-auto mb-10 max-w-2xl text-center">
      <h2 class="text-2xl sm:text-3xl font-semibold text-foreground">{heading}</h2>
      <p class="mt-2 text-sm sm:text-base text-muted-foreground">{intro}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {members.map((member) => (
        <div class="flex flex-col rounded-xl border border-border bg-card p-5 shadow-sm">
          <div class="flex items-center gap-4">
            <img
              src={member.image}
              alt={member.imageAlt || member.name}
              class="h-16 w-16 rounded-full object-cover"
            />
            <div>
              <p class="text-sm font-semibold text-card-foreground">{member.name}</p>
              <p class="text-xs uppercase tracking-wide text-muted-foreground">{member.role}</p>
            </div>
          </div>

          <p class="mt-3 text-sm text-muted-foreground">{member.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

